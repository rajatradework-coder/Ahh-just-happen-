  <iframe
    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3773.8788659985944!2d72.8388!3d18.9488!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be7ce5b1c67e3b7%3A0x0!2sMasjid+Bunder%2C+Mumbai%2C+Maharashtra!5e0!3m2!1sen!2sin!4v1234567890"
    width="100%" height="400" style="border:0;" allowfullscreen="" loading="lazy">
  </iframe>
</div>
