<!-- PAGE HEADER -->
<div class="page-header">
  <div class="container">
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height:200px;">
      <h3 class="display-4 text-white text-uppercase">Contact Us</h3>
      <div class="d-inline-flex">
        <p class="m-0 text-white"><a href="/" class="text-white">Home</a></p>
        <p class="m-0 text-white px-2">/</p>
        <p class="m-0 text-white">Contact</p>
      </div>
    </div>
  </div>
</div>

<div class="container-fluid py-5 px-sm-3 px-md-5">
  <div class="row">
    <!-- CONTACT INFO -->
    <div class="col-lg-4 mb-5 mb-lg-0">
      <h5 class="text-primary text-uppercase mb-3 letter-spacing">Get In Touch</h5>
      <h2 class="mb-4">Contact Information</h2>
      <div class="d-flex mb-4">
        <div class="contact-icon bg-primary rounded-circle d-flex align-items-center justify-content-center mr-3" style="min-width:50px;height:50px;">
          <i class="fa fa-map-marker-alt text-white"></i>
        </div>
        <div>
          <h6 class="font-weight-bold mb-1">Our Address</h6>
          <p class="mb-0">Latif House, Office No 24, Sant Tukaram Road, Masjid Bunder(East), Mumbai 400009</p>
        </div>
      </div>
      <div class="d-flex mb-4">
        <div class="contact-icon bg-primary rounded-circle d-flex align-items-center justify-content-center mr-3" style="min-width:50px;height:50px;">
          <i class="fa fa-phone-alt text-white"></i>
        </div>
        <div>
          <h6 class="font-weight-bold mb-1">Call Us</h6>
          <p class="mb-0">02223482676</p>
          <p class="mb-0">+91-9324093211</p>
        </div>
      </div>
      <div class="d-flex mb-4">
        <div class="contact-icon bg-primary rounded-circle d-flex align-items-center justify-content-center mr-3" style="min-width:50px;height:50px;">
          <i class="fa fa-envelope text-white"></i>
        </div>
        <div>
          <h6 class="font-weight-bold mb-1">Email Us</h6>
          <p class="mb-0">mail@rajatrade.com</p>
        </div>
      </div>
      <div class="d-flex mb-4">
        <div class="contact-icon bg-primary rounded-circle d-flex align-items-center justify-content-center mr-3" style="min-width:50px;height:50px;">
          <i class="fa fa-clock text-white"></i>
        </div>
        <div>
          <h6 class="font-weight-bold mb-1">Office Hours</h6>
          <p class="mb-0">Monday - Saturday: 9:30 AM - 6:00 PM</p>
        </div>
      </div>
    </div>

    <!-- CONTACT FORM -->
    <div class="col-lg-8">
      <h5 class="text-primary text-uppercase mb-3 letter-spacing">Send Message</h5>
      <h2 class="mb-4">Get a Free Quote</h2>

      {{#if success}}
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa fa-check-circle mr-2"></i>{{success}}
        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
      </div>
      {{/if}}

      {{#if error}}
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa fa-exclamation-circle mr-2"></i>{{error}}
        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
      </div>
      {{/if}}

      <form action="/contact" method="POST" id="contactForm">
        <div class="row">
          <div class="col-md-6">
            <div class="form-group">
              <label>Your Name <span class="text-danger">*</span></label>
              <input type="text" name="name" class="form-control" placeholder="Your Name" value="{{formData.name}}" required/>
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-group">
              <label>Your Email <span class="text-danger">*</span></label>
              <input type="email" name="email" class="form-control" placeholder="Your Email" value="{{formData.email}}" required/>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-md-6">
            <div class="form-group">
              <label>Phone Number</label>
              <input type="tel" name="phone" class="form-control" placeholder="Your Phone" value="{{formData.phone}}"/>
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-group">
              <label>Subject</label>
              <select name="subject" class="form-control">
                <option value="">-- Select Service --</option>
                <option value="RoSCTL Licence">RoSCTL Licence</option>
                <option value="IEC Code">IEC Code</option>
                <option value="MEIS & SEIS Incentives">MEIS &amp; SEIS Incentives</option>
                <option value="EPCG License">EPCG License</option>
                <option value="Advance License">Advance License</option>
                <option value="Export House Certificate">Export House Certificate</option>
                <option value="RCMC Application">RCMC Application</option>
                <option value="Certificate of Origin">Certificate of Origin</option>
                <option value="Digital Signature">Digital Signature</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label>Message <span class="text-danger">*</span></label>
          <textarea name="message" class="form-control" rows="6" placeholder="Describe your requirement..." required>{{formData.message}}</textarea>
        </div>
        <button type="submit" class="btn btn-primary py-3 px-5">
          <i class="fa fa-paper-plane mr-2"></i>Send Message
        </button>
      </form>
    </div>
  </div>
</div>

